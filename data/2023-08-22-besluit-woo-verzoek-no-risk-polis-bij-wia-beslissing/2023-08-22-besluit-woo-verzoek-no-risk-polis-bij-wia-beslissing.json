      "type": "paragraph",
      "page": 1,
      "bbox": [
        102.6,
        614.97,
        197.45,
        623.97
      ],
      "text": "late beoordeling WIA",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        76.56,
        626.37,
        432.13,
        635.37
      ],
      "text": "2 Handreiking beoordeling aanvraag No-riskpolis bij te late Openbaar",
      "source": "text"
