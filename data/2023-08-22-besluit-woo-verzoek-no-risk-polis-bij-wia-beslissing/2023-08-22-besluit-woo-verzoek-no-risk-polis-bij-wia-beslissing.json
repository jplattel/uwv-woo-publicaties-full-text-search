    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.81,
        692.47,
        522.7,
        701.47
      ],
      "text": "WIA en tijdige RIV-toets”. De namen van onze medewerkers zijn gelakt op grond van artikel 5.1 lid",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.81,
        703.39,
        164.23,
        712.39
      ],
      "text": "2 sub e van de Woo.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        725.35,
        120.72,
        734.35
      ],
      "text": "Publicatie",
