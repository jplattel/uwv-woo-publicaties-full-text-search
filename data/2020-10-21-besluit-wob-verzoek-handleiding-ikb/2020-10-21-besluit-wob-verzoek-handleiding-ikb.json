      "bbox": [
        71.3,
        294.87,
        295.68,
        302.91
      ],
      "text": "Beslissing op uw verzoek om informatie d.d. 10-8-2020",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        412.3,
        305.07,
        415.95,
