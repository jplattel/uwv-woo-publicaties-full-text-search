      "bbox": [
        408.18,
        114.12,
        435.98,
        124.12
      ],
      "text": "10.2.e",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        120.24,
        200.47,
        128.28
      ],
      "text": "Medewerkers Bezwaar & Beroep",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        409.18,
        154.14,
        432.14,
