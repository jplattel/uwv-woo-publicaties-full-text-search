      "page": 4,
      "bbox": [
        70.94,
        701.24,
        491.96,
        709.28
      ],
      "text": "overeenkomstige toepassing is wanneer geen sprake is van een aanvraag. Daardoor kan de herleving of",
      "source": "text"
    },
