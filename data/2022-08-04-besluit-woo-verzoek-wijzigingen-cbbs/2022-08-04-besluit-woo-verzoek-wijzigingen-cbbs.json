    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        71.64,
        295.96,
        290.96,
        304.0
      ],
      "text": "Beslissing op uw verzoek om informatie d.d. 4-4-2022",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        412.44,
        306.28,
