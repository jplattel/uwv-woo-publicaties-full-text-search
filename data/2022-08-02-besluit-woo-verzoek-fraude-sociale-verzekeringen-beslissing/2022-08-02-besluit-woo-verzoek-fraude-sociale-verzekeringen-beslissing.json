    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        76.58,
        299.99,
        480.81,
        308.99
      ],
      "text": "3. Werkinstructie Thema Gefingeerd Dienstverband Reeds deels openbaar",
      "source": "text"
    },
