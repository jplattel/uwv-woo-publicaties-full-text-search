      ],
      "text": "bezwaarschrift ook altijd uw telefoonnummer. Dan kunnen wij contact met u opnemen als we vragen",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        71.25,
        415.21,
        107.86,
        424.21
      ],
      "text": "hebben.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        71.25,
        451.2,
        133.83,
        460.2
      ],
      "text": "Hoogachtend,",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        71.25,
        463.2,
        308.07,
        472.2
      ],
      "text": "De minister van Sociale Zaken en Werkgelegenheid,",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        71.25,
        475.2,
        135.4,
        484.2
      ],
      "text": "Namens deze,",
