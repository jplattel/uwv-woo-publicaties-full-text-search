    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        71.25,
        523.2,
        282.34,
        532.2
      ],
      "text": "Uitvoeringsinstituut werknemersverzekeringen",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        71.25,
        571.19,
