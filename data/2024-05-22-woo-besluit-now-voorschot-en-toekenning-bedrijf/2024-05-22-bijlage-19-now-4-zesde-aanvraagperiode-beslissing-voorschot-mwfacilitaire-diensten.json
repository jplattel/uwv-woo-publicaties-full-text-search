      "type": "paragraph",
      "page": 2,
      "bbox": [
        71.25,
        355.22,
        138.16,
        364.22
      ],
      "text": "Postbus 59602",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        71.25,
        367.22,
        163.91,
