      "type": "paragraph",
      "page": 1,
      "bbox": [
        58.57,
        433.58,
        420.57,
        440.38
      ],
      "text": "Voorschot Tussen €40.000 en €125.000",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        56.69,
        443.63,
        238.76,
        451.13
      ],
      "text": "Hoe hoog wordt uw definitieve tegemoetkoming geschat?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        58.57,
        453.87,
        420.57,
        460.67
      ],
      "text": "Schatting definitieve tegemoetkoming Tussen €40.000 en €125.000",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        58.57,
        463.75,
        420.55,
        470.55
      ],
      "text": "Heeft u een derdenverklaring? Ja, ik heb al een verklaring",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        56.69,
        473.8,
        107.31,
        481.3
      ],
      "text": "Gegevens derde",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        58.57,
        484.04,
        78.59,
        490.84
      ],
      "text": "Naam:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        58.57,
        493.92,
        101.27,
        500.72
      ],
      "text": "KVK-nummer:",
      "source": "text"
