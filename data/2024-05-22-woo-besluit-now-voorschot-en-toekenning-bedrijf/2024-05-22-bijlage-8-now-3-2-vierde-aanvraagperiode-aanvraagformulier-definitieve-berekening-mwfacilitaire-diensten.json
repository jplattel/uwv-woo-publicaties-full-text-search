      "type": "paragraph",
      "page": 1,
      "bbox": [
        56.69,
        403.04,
        134.39,
        410.54
      ],
      "text": "Wat is uw omzetverlies?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        58.57,
        413.29,
        355.17,
        420.09
      ],
      "text": "Omzetverlies (in hele procenten) 95 %",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        56.69,
        423.34,
        206.27,
        430.84
      ],
      "text": "Hoeveel voorschot heeft u in totaal ontvangen?",
      "source": "text"
    },
