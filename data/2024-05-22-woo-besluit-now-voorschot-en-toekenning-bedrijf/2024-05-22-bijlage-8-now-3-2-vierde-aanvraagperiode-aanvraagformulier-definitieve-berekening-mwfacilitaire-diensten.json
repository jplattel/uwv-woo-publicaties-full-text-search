    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        58.57,
        352.41,
        384.28,
        359.21
      ],
      "text": "Eerste maand na overgang van onderneming augustus 2019",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        56.69,
        362.46,
        214.16,
        369.96
      ],
      "text": "Wat was uw netto-omzet in de referentieperiode?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        58.57,
        372.7,
        364.25,
        379.5
      ],
