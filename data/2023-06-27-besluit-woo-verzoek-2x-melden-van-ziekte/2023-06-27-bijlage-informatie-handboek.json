  "blocks": [
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        78.57,
        480.62,
        90.09
      ],
      "text": "Uitgangspunt voor het proces bij UWV is dat de van toepassing zijnde rechtsgrond uit de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        98.03,
        477.89,
        109.55
      ],
      "text": "ziekteaangifte moet blijken. UWV onderzoekt niet ambtshalve of er een rechtsgrond van",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        117.59,
        445.85,
        129.11
      ],
      "text": "toepassing is die gunstiger is voor de werknemer danwel de werkgever ERD ZW.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        137.03,
        521.14,
        148.55
      ],
      "text": "Maar als een werkgever al eerder een ziekteaangifte heeft gedaan en hij komt er later achter dat er",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        156.59,
        469.5,
        168.11
      ],
      "text": "aanspraak was op ziekengeld op een andere rechtsgrond, dan is de datum van de eerste",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        176.03,
        369.48,
        187.55
      ],
      "text": "ziekteaangifte de maatstaf voor de beoordeling van de tijdigheid.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        195.59,
        509.89,
        207.11
      ],
      "text": "Dit komt voor als de werkgever eerder een ziekteaangifte heeft gedaan voor een werknemer die",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        215.03,
        506.49,
        226.55
      ],
      "text": "ziek uit dienst is gegaan, die is ziek gemeld als uitzendkracht met uitzendbeding of werknemer",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        234.59,
        492.8,
        246.11
      ],
      "text": "met een fictieve dienstbetrekking en later een claim doet voor ziekengeld wegens no-risk of",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        254.03,
        219.74,
        265.55
      ],
      "text": "wegens zwangerschapsklachten.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        273.59,
        470.49,
        285.11
      ],
      "text": "Uitgangspunt bij dit beleid is dat de rechter vindt dat UWV bij een ziekteaangifte moet",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        293.06,
        498.3,
        304.58
      ],
      "text": "onderkennen of onderzoeken welke rechtsgrond daaraan ten grondslag ligt. De wet geeft niet",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        312.62,
        518.93,
        324.14
      ],
      "text": "duidelijk aan dat de werkgever bij een ziekteaangifte de rechtsgrond uitdrukkelijk moet aangeven",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        332.06,
        295.66,
        343.58
      ],
      "text": "(bijvoorbeeld dat het om een no-risk claim gaat).",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        351.62,
        511.5,
        363.14
      ],
      "text": "Het ziekengeld wordt dan ook met maximaal een jaar terugwerkende kracht toegekend vanaf de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        371.06,
        199.61,
        382.58
      ],
      "text": "datum eerste ziekteaangifte.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        390.62,
        482.17,
        402.14
      ],
      "text": "Voor de toerekening van het ziekengeld aan de ERD heeft dit gevolgen. UWV betaalt het",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        410.06,
        501.58,
        421.58
      ],
      "text": "ziekengeld in plaats van de ERD. Zie het Schema: Wie betaalt het ziekengeld: ERD of UWV.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        443.16,
        503.02,
        455.16
      ],
      "text": "Eigenrisicodrager ZW (ERD-ZW) - Handboek omgeving - UWV : Handboek omgeving –",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        462.74,
        175.45,
        474.74
      ],
      "text": "UWV (publishone.nl)",
