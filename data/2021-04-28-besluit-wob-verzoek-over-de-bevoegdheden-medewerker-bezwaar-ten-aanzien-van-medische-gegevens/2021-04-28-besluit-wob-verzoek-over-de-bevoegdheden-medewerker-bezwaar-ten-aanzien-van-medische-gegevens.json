      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        68.79,
        640.58,
        316.74,
        649.08
      ],
      "text": "Ik hoop u hiermee voldoende te hebben geïnformeerd.",
      "source": "text"
