      "type": "paragraph",
      "page": 3,
      "bbox": [
        66.0,
        234.01,
        465.54,
        249.01
      ],
      "text": "Als de cliënt aan de informatieplicht heeft voldaan is hij objectief niet verwijtbaar.",
      "source": "text"
    },
