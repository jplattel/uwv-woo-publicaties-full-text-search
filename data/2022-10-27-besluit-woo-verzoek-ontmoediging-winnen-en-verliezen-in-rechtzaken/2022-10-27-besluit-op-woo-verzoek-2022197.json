      "bbox": [
        71.3,
        294.87,
        295.68,
        302.91
      ],
      "text": "Beslissing op uw verzoek om informatie d.d. 30-9-2022",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        412.18,
