  "blocks": [
    {
      "type": "heading",
      "page": 1,
      "bbox": [
        70.8,
        75.0,
        302.02,
        89.04
      ],
      "text": "Oud beleid van voor 1 januari 2012",
      "source": "text"
    },
    {
      "type": "heading",
      "page": 1,
      "bbox": [
        70.8,
        107.28,
        131.57,
        121.32
      ],
      "text": "Maatman",
      "source": "text"
    },
    {
      "type": "heading",
      "page": 1,
      "bbox": [
        70.8,
        135.07,
        216.6,
        148.03
      ],
      "text": "Waarom een maatman?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        148.36,
        493.08,
        157.36
      ],
      "text": "Het begrip ‘maatman’ staat al lange tijd centraal bij arbeidsongeschiktheid. Hoewel we het niet langer over",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        158.8,
        513.68,
        167.8
      ],
      "text": "arbeidsongeschiktheid hebben, maar over verdienvermogen, is dat in de Wet Wajong niet anders. Aan de hand",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        169.13,
        511.52,
        178.13
      ],
      "text": "van het maatmaninkomen stellen we vast of we de klant als jonggehandicapte kunnen aanmerken. Een van de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        179.45,
        505.66,
        188.45
      ],
      "text": "voorwaarden daarvoor is dat de klant 52 weken niet meer dan 75% van het maatmaninkomen kon verdienen.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        202.5,
        491.71,
        214.5
      ],
      "text": "Waarom stellen we de maatgevende arbeid bij de nieuwe Wajong anders vast?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        215.56,
        523.29,
        224.56
      ],
      "text": "Het vaststellen van de maatgevende arbeid van een jonggehandicapte wijkt op een onderdeel wezenlijk af van de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        226.0,
        522.35,
        235.0
      ],
      "text": "vaststelling voor WAO en WIA: de meeste jonggehandicapten hebben nog niet gewerkt als zij zich bij ons melden",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        236.33,
        495.65,
        245.33
      ],
      "text": "voor ondersteuning. Hierdoor is het begrip maatgevende arbeid minder van belang. Alleen als de klant een",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        246.65,
        509.14,
        255.65
      ],
      "text": "arbeidsverleden heeft, is vaststelling van de maatgevende arbeid volgens de regels van toegevoegde waarde.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        269.7,
        255.67,
        281.7
      ],
      "text": "Wat is de basis voor de maatman?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        282.76,
        514.2,
        291.76
      ],
      "text": "De wetgever is bij de vaststelling van de maatman niet uitgegaan van de arbeidswaarde van de klant zelf, maar",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        293.2,
        445.16,
        302.2
      ],
      "text": "van de arbeidswaarde van de ‘valide gelijksoortige’. Bij de vaststelling hiervan hanteren we de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        303.28,
        107.36,
        312.28
      ],
      "text": "volgende",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        109.92,
        303.74,
        516.9,
        312.74
      ],
      "text": "vuistregel: we gaan uit van wat iemand verdient met de arbeid die de klant zelf heeft verricht en",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        314.07,
        494.36,
        323.07
      ],
      "text": "nog zou verrichten als hij niet arbeidsongeschikt zou zijn in het aantal uren dat hoort bij de fulltime",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        324.39,
        184.9,
        333.39
      ],
      "text": "uitoefening van de functie.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        347.34,
        235.03,
        359.34
      ],
      "text": "Waar bestaat de maatman uit?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        360.16,
        265.51,
        369.16
      ],
      "text": "Het begrip kent een onderverdeling in:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        114.96,
        360.62,
        154.42,
        369.62
      ],
      "text": "maatman",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        370.5,
        74.94,
        379.5
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        381.76,
        327.46,
        390.76
      ],
      "text": "maatgevende arbeid: het soort werk dat we maatgevend achten.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        391.86,
        74.94,
        400.86
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        403.13,
        480.7,
        412.13
      ],
      "text": "maatgevende omvang: de tijdsduur die hoort bij de maatgevende arbeid, bijvoorbeeld 38 uur per week.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        413.23,
        74.94,
        422.23
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        424.5,
        487.66,
        433.5
      ],
      "text": "maatmanloon: het bedrag dat de klant met de maatgevende arbeid in de maatgevende omvang verdient,",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        434.82,
        173.02,
        443.82
      ],
      "text": "bijvoorbeeld € 15 per uur.",
      "source": "text"
    },
    {
      "type": "heading",
      "page": 1,
      "bbox": [
        70.8,
        458.83,
        325.12,
        471.79
      ],
      "text": "Hoe bepalen we de maatgevende arbeid?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        472.12,
        487.65,
        481.12
      ],
      "text": "De hoofdregel voor het bepalen van de maatgevende arbeid is in eerste instantie geformuleerd vanuit de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        482.45,
        161.5,
        491.45
      ],
      "text": "verzekeringsgedachte:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        493.1,
        462.42,
        502.1
      ],
      "text": "de laatst verrichte arbeid voordat het verdienvermogen onder de 75% zakte, is maatgevend.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        503.2,
        520.78,
        512.2
      ],
      "text": "Algemeen geldt dat we voor jonggehandicapten geen maatgevende arbeid kunnen vaststellen, omdat zij nog niet",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        513.52,
        251.98,
        522.52
      ],
      "text": "aan het arbeidsproces hebben deelgenomen.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        103.32,
        533.93,
        514.27,
        542.93
      ],
      "text": "Er zijn vanzelfsprekend uitzonderingen: de klant kan tijdens en naast zijn studie hebben gewerkt. Soms",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        534.39,
        100.92,
        543.39
      ],
      "text": "Let op!",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.79,
        544.61,
        518.12,
        553.61
      ],
      "text": "gaat het duidelijk om bijbaantjes, zoals krantenbezorger. Dan kunnen we geen volwaardige maatgevende arbeid",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.79,
        554.93,
        520.16,
        563.93
      ],
      "text": "vaststellen, omdat die functie per definitie niet voltijds bestaat. Het kan ook zijn, dat het gaat om werkzaamheden",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.79,
        565.26,
        510.07,
        574.26
      ],
      "text": "in deeltijd, die ook voorkomen als voltijdse arbeid. In dat geval kunnen we op basis van die feitelijke arbeid wél",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.79,
        575.58,
        501.65,
        584.58
      ],
      "text": "een maatgevende arbeid bepalen: de arbeid die een gezonde persoon in deze gelijkwaardige functie voltijds",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.79,
        586.02,
        102.93,
        595.02
      ],
      "text": "verricht.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        609.06,
        448.39,
        621.06
      ],
      "text": "Hebben jonggehandicapten met arbeidsverleden een maatmanfunctie?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        622.12,
        473.13,
        631.12
      ],
      "text": "Voor jonggehandicapten kunnen we in de regel geen maatgevende arbeid aanwijzen, omdat ze geen",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        632.45,
        495.19,
        641.45
      ],
      "text": "arbeidsverleden hebben. Zodra de jonggehandicapte gaat werken, kunnen we de maatgevende arbeid wel",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        642.77,
        255.1,
        651.77
      ],
      "text": "bepalen. Dat doen we op de volgende manier:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        653.43,
        523.99,
        662.43
      ],
      "text": "de maatgevende arbeid bepalen we door een vergelijking te maken met de arbeid van de volledig gezonde",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        663.75,
        198.34,
        672.75
      ],
      "text": "personen in datzelfde beroep.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        684.17,
        523.6,
        693.17
      ],
      "text": "De maatmanomvang en het maatmanloon bepalen we door vergelijking met de volledige omvang en het volledige",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        694.61,
        508.31,
        703.61
      ],
      "text": "loon dat gezonde personen in datzelfde beroep verdienen. De klant hoeft de arbeid niet voltijds uit te oefenen.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        715.47,
        100.92,
        724.47
      ],
      "text": "Let op!",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        725.35,
        74.94,
        734.35
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        736.61,
        523.64,
        745.61
      ],
      "text": "Het werken in beschutte omgeving (WSW) of gesubsidieerde arbeid beschouwen we voor de nieuwe Wet Wajong",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        746.94,
        186.34,
        755.94
      ],
      "text": "niet als maatgevende arbeid!",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        757.15,
        74.94,
        766.15
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        73.12,
        499.76,
        82.12
      ],
      "text": "Deze maatmanwijziging is niet beperkt tot de eerste keer dat de klant gaat werken. Bij iedere erop volgende",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        83.56,
        524.26,
        92.56
      ],
      "text": "wijziging van functie of beroep stellen we steeds de maatgevende arbeid en in principe ook het maatmanloon vast",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        93.89,
        212.98,
        102.89
      ],
      "text": "aan de hand van de nieuwe functie.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        103.99,
        74.94,
        112.99
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        115.25,
        463.66,
        124.25
      ],
      "text": "Als we de maatgevende arbeid kunnen bepalen, heeft dat als consequentie, dat we vervolgens het",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        125.58,
        509.24,
        134.58
      ],
      "text": "verdienvermogen van de jonggehandicapte moeten beoordelen. Ook moeten we opnieuw vaststellen of we de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        136.02,
        393.23,
        145.02
      ],
      "text": "klant ook na de maatmanwijziging nog als jonggehandicapte kunnen aanmerken.",
      "source": "text"
    },
    {
      "type": "heading",
      "page": 2,
      "bbox": [
        70.8,
        159.91,
        335.91,
        172.87
      ],
      "text": "Hoe bepalen we de maatgevende omvang?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        173.2,
        447.82,
        182.2
      ],
      "text": "De maatgevende omvang is het aantal uren dat hoort bij de vastgestelde maatgevende arbeid.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        183.64,
        443.03,
        192.64
      ],
      "text": "Het is daarbij op zichzelf niet van belang, of de klant die arbeid voltijds of in deeltijd verrichtte.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        206.7,
        337.63,
        218.7
      ],
      "text": "Wanneer is een nadere beoordeling noodzakelijk?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        219.76,
        326.5,
        228.76
      ],
      "text": "In de volgende situaties is een nadere beoordeling noodzakelijk:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        229.86,
        74.94,
        238.86
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        241.13,
        510.21,
        250.13
      ],
      "text": "Bij maatgevende arbeid is vermeld dat we in het algemeen voor jonggehandicapten geen maatgevende arbeid",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        251.45,
        510.2,
        260.45
      ],
      "text": "kunnen aanwijzen, omdat ze geen arbeidsverleden hebben. Wel kunnen we in deze situatie een maatmanloon",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        261.78,
        519.8,
        270.78
      ],
      "text": "vaststellen Dat is een voor de leeftijd van de jonggehandicapte geldend wettelijk minimumloon. Daarvoor kunnen",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        272.22,
        498.22,
        281.22
      ],
      "text": "we ook een omvang vaststellen. Dat is de omvang die hoort bij dat wettelijk minimumloon: 38 uur per week.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        282.31,
        74.94,
        291.31
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        293.58,
        429.21,
        302.58
      ],
      "text": "Voor jonggehandicapten gelden uitzonderingen bij werkaanvaarding en bij toepassing van",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        303.91,
        514.13,
        312.91
      ],
      "text": "de hardheidsclausule of naar hardheidsclausule in WIA handboek. Bepalend voor de vaststelling van het aantal",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        314.23,
        360.94,
        323.23
      ],
      "text": "uren is de vergelijking met een gezonde persoon met gelijkwaardig werk.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        324.33,
        74.94,
        333.33
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        335.59,
        511.77,
        344.59
      ],
      "text": "De maatgevende omvang speelt een rol bij het berekenen van het maatmanloon. Maar ook bij het bepalen van",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        346.03,
        198.94,
        355.03
      ],
      "text": "de resterende verdiencapaciteit.",
      "source": "text"
    },
    {
      "type": "heading",
      "page": 2,
      "bbox": [
        70.8,
        369.91,
        288.14,
        382.87
      ],
      "text": "Hoe bepalen we het maatmanloon?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        383.2,
        488.23,
        392.2
      ],
      "text": "De hoofdregel bij het bepalen van het maatmaninkomen is dat we aansluiten bij het inkomen dat de klant",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        393.64,
        221.03,
        402.64
      ],
      "text": "verdiende in de maatgevende functie:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        404.18,
        521.96,
        413.18
      ],
      "text": "Het maatmanloon is het bedrag dat de klant per uur verdient, op basis van het aantal uren dat hoort bij de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        414.51,
        217.43,
        423.51
      ],
      "text": "vastgestelde maatgevende arbeid.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        424.6,
        513.66,
        433.6
      ],
      "text": "Het maatmanloon van de jonggehandicapte voor wie we geen maatgevende arbeid kunnen vaststellen, is gelijk",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        435.04,
        485.12,
        444.04
      ],
      "text": "aan het voor de leeftijd van de klant geldend wettelijk minimum (jeugd)loon inclusief vakantietoeslag. De",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        445.37,
        126.94,
        454.37
      ],
      "text": "berekening is:",
      "source": "text"
    },
    {
      "type": "heading",
      "page": 2,
      "bbox": [
        100.92,
        455.91,
        216.48,
        464.91
      ],
      "text": "WML * 1,08 * 12 / (52,2 * 38)",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.81,
        466.0,
        521.62,
        475.0
      ],
      "text": "Voor de werkende jonggehandicapten voor wie een volwaardige maatmanfunctie kan worden bepaald, stellen we",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        476.44,
        306.48,
        485.44
      ],
      "text": "het maatmanloon vast volgens de regels voor werknemers.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        499.5,
        391.03,
        511.5
      ],
      "text": "Kan het maatmaninkomen hoger zijn dan het minimumloon?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        512.57,
        479.1,
        521.57
      ],
      "text": "De hardheidsclausule voor jonggehandicapten houdt in dat het maatmanloon hoger is dan het wettelijk",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        522.89,
        479.13,
        531.89
      ],
      "text": "minimum(jeugd)loon als de jonggehandicapte voldoet aan de hierna genoemde voorwaarden. Toen de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        532.97,
        466.66,
        541.97
      ],
      "text": "jonggehandicapte had hij:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        390.08,
        532.97,
        435.1,
        542.43
      ],
      "text": "verdienen,",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        144.48,
        533.43,
        387.52,
        542.43
      ],
      "text": "niet langer in staat was 75% van het maatmaninkomen te",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        543.3,
        74.94,
        552.3
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        554.57,
        478.78,
        563.57
      ],
      "text": "binnen een jaar voorafgaand aan deze dag een diploma gehaald van een beroepsgerichte opleiding of",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        564.78,
        74.94,
        573.78
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        576.05,
        410.14,
        585.05
      ],
      "text": "voor zijn 30ste verjaardag een diploma behaald van een beroepsgerichte opleiding of",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        586.15,
        74.94,
        595.15
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        597.42,
        349.63,
        606.42
      ],
      "text": "voorafgaand een diploma gehaald van een beroepsgerichte opleiding.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        607.74,
        515.12,
        616.74
      ],
      "text": "In alle bovenstaande situaties geldt als extra eis dat het aanvangssalaris in dat beroep minstens anderhalf maal",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        618.06,
        239.51,
        627.06
      ],
      "text": "het wettelijk minimumloon moet bedragen.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        103.32,
        638.58,
        473.62,
        647.58
      ],
      "text": "Als de klant aan een van deze voorwaarden voldoet, stellen we het maatmanloon vast op dat",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        639.04,
        100.92,
        648.04
      ],
      "text": "Let op!",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        649.14,
        504.56,
        658.14
      ],
      "text": "aanvangssalaris. Dat salaris is daarmee minstens anderhalf maal het wettelijk minimumloon, maar hoger kan",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        659.46,
        155.98,
        668.46
      ],
      "text": "vanzelfsprekend ook.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        682.5,
        463.03,
        694.5
      ],
      "text": "Hoe bepaal je het maatmaninkomen van de werkende jonggehandicapte?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        695.56,
        499.65,
        704.56
      ],
      "text": "Voor een jonggehandicapte die wel inkomsten uit arbeid heeft, stellen we het maatmanloon vast op wat een",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        706.0,
        484.3,
        715.0
      ],
      "text": "gezonde persoon van dezelfde leeftijd in die functie tijdens de normale volledige werktijd zou verdienen.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        130.92,
        716.08,
        497.71,
        725.08
      ],
      "text": "ook in de situatie waarbij een jonggehandicapte is gaan werken, kan het voorkomen, dat het",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        716.08,
        128.38,
        725.54
      ],
      "text": "Uitzondering:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        726.64,
        517.18,
        735.64
      ],
      "text": "maatmaninkomen door toepassing van de hardheidsclausule hoger zou uitvallen dan het wettelijk minimumloon.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        736.96,
        438.1,
        745.96
      ],
      "text": "In dat geval moeten we het hogere maatmaninkomen van de hardheidsclausule aanhouden.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.8,
        73.86,
        489.4,
        85.86
      ],
      "text": "Houden we bij de beoordeling van een klant rekening met inkomsten uit WSW-",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.8,
        87.66,
        110.95,
        99.66
      ],
      "text": "arbeid?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.8,
        100.72,
        514.53,
        109.72
      ],
      "text": "Een maatmanloonwijziging kan niet plaatsvinden, als het gaat om een klant die arbeid in WSW-verband is gaan",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.81,
        111.16,
        513.82,
        120.16
      ],
      "text": "verrichten. Bij een beoordeling houden we nooit rekening met (eventuele) inkomsten uit WSW-arbeid. De WSW",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.81,
        121.49,
        505.66,
        130.49
      ],
      "text": "kent ook de mogelijkheid om een klant met subsidie een arbeidsplaats in het vrije bedrijf te bezorgen. In deze",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.81,
        131.81,
        523.21,
        140.81
      ],
      "text": "situatie is er geen dienstverband met de sociale werkplaats, maar met een werkgever in het vrije bedrijf. Ook voor",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.81,
        142.13,
        485.72,
        151.13
      ],
      "text": "deze situatie geldt de regel, dat bij de beoordeling geen rekening met die arbeid mag worden gehouden.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.8,
        165.3,
        341.59,
        177.3
      ],
      "text": "Wijzigt het maatmanloon na de eerste vaststelling?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.8,
        178.36,
        497.62,
        187.36
      ],
      "text": "Als de hoogte van het wettelijk minimumloon van de jonggehandicapte kan veranderen, dan kunnen we het",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.8,
        188.69,
        492.21,
        197.69
      ],
      "text": "maatmaninkomen ook wijzigen. We passen het maatmaninkomen van deze jonggehandicapte aan bij een",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.81,
        199.01,
        179.51,
        208.01
      ],
      "text": "eerstvolgende beoordeling.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.8,
        222.06,
        380.35,
        234.06
      ],
      "text": "Wijzigt het maatmaninkomen ook na een maatmanwissel?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.8,
        235.12,
        489.68,
        244.12
      ],
      "text": "Bij een wijziging van de maatgevende arbeid (bijvoorbeeld bij nieuw verworven bekwaamheden of bij een",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.8,
        245.56,
        501.65,
        254.56
      ],
      "text": "jonggehandicapte die gaat werken of van arbeid verandert) stellen we ook een nieuw maatmanloon vast. De",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.8,
        255.89,
        309.1,
        264.89
      ],
      "text": "indexering begint vanaf dat moment weer opnieuw te lopen.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.8,
        278.94,
        332.35,
        290.94
      ],
      "text": "Wijzigt het maatmaninkomen bij elke verjaardag?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.8,
        292.0,
        475.67,
        301.0
      ],
      "text": "Bij elke leeftijdsverhoging van jongeren tot 23 jaar gaat het om een maatmanwisseling. We stellen het",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.8,
        302.33,
        522.18,
        311.33
      ],
      "text": "maatmaninkomen vast op het voor die hogere leeftijd geldende minimumjeugdloon totdat de leeftijd van 23 jaar is",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.8,
        312.77,
        265.54,
        321.77
      ],
      "text": "bereikt. Daarna wordt de CBS-index gehanteerd.",
      "source": "text"
    }
  ]
}
