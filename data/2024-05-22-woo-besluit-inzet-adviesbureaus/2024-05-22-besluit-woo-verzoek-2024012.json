    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        425.12,
        485.04,
        434.12
      ],
      "text": "verschillende besluiten op uw verzoeken, waarbij UWV de nummering aanhoudt die u heeft",
