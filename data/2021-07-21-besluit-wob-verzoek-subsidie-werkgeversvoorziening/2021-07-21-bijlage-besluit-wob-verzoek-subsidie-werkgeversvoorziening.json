    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        198.0,
        1079.0,
        1112.0,
        1104.0
      ],
      "text": "aangevraagd. U krijgt de subsidie niet. In de brief leest u hierover meer.",
