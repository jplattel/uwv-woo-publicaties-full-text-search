    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        197.0,
        1146.0,
        1370.0,
        1171.0
      ],
      "text": "Volgens onze arbeidsdeskundige is de voorziening medisch gezien niet nodig. Daarom kunt u",
