      "page": 1,
      "bbox": [
        198.0,
        1385.0,
        1293.0,
        1411.0
      ],
      "text": "Er is door de specifieke BV één aanvraag gedaan voor een subsidie voor een generieke",
      "source": "ocr"
    },
