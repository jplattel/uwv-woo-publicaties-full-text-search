  "pdf_url": "https://www.uwv.nl/assets-kai/files/a045e118-2789-41aa-95d0-54974635c19a/bijlage-2-inkomen-van-de-beroepsbeoefenaar.pdf",
  "publication_title": "Besluit Woo-verzoek inkomen beroepsbeoefenaren bij WAZ",
  "publication_date": "2023-05-09T00:00:00Z",
  "publication_type": "WOO publicatie",
