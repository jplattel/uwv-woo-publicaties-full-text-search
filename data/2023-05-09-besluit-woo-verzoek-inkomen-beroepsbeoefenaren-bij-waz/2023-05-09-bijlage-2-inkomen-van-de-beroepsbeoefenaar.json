  "blocks": [
    {
      "type": "heading",
      "page": 1,
      "bbox": [
        70.82,
        88.8,
        368.84,
        109.8
      ],
      "text": "Inkomen van de beroepsbeoefenaar",
      "source": "text"
    },
    {
      "type": "heading",
      "page": 1,
      "bbox": [
        70.82,
        127.6,
        148.79,
        146.56
      ],
      "text": "Algemeen",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        163.7,
        125.02,
        178.7
      ],
      "text": "Inleiding",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        194.27,
        511.81,
        205.79
      ],
      "text": "Het inkomensbegrip voor de beroepsbeoefenaar is met ingang van 1 januari 2001 aangepast aan",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        213.83,
        411.7,
        225.35
      ],
      "text": "de Wet IB 2001. Vanaf 2001 zijn verwervingskosten niet meer aftrekbaar.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        233.27,
        507.51,
        244.79
      ],
      "text": "Voor belastingjaren tot 2001 wordt onder het inkomen van de beroepsbeoefenaar verstaan: alle",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        252.83,
        488.82,
        264.35
      ],
      "text": "andere dan uit dienstbetrekking in de zin van de WAO genoten inkomsten en voordelen uit",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        272.27,
        519.79,
        283.79
      ],
      "text": "tegenwoordige arbeid nadat deze zijn verminderd met de aftrekbare kosten die betrekking hebben",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        291.86,
        267.48,
        303.38
      ],
      "text": "op de inkomsten uit tegenwoordige arbeid.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        311.3,
        519.39,
        322.82
      ],
      "text": "Vanaf het belastingjaar 2001 wordt onder het inkomen van de beroepsbeoefenaar verstaan: al wat",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        330.86,
        492.65,
        342.38
      ],
      "text": "anders dan uit dienstbetrekking in de zin van de WAO wordt genoten uit belastbaar loon uit",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        350.3,
        422.84,
        361.82
      ],
      "text": "tegenwoordige arbeid of als belastbaar resultaat uit overige werkzaamheden.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        369.86,
        216.71,
        381.38
      ],
      "text": "artikel 3 Inkomensbesluit WAZ",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        398.45,
        287.8,
        413.45
      ],
      "text": "Inkomsten uit tegenwoordige arbeid",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        429.14,
        486.23,
        440.66
      ],
      "text": "Als betrokkene niet in een dienstbetrekking in de zin van de WAO werkzaam is, wordt als",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        448.58,
        520.61,
        460.1
      ],
      "text": "opbrengst uit arbeid beschouwd alle gelden en alle andere voordelen die uit hoofde van die arbeid",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        468.16,
        147.58,
        479.68
      ],
      "text": "worden genoten.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        487.6,
        511.29,
        499.12
      ],
      "text": "Voor zover betrokkene beloning in natura ontving, is ook hier de beschikking loon innatura van",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        507.16,
        122.25,
        518.68
      ],
      "text": "toepassing.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        526.6,
        492.4,
        538.12
      ],
      "text": "Voor de bepaling van het inkomen van een beroepsbeoefenaar moet je alle niet als winst uit",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        546.16,
        515.81,
        557.68
      ],
      "text": "onderneming aan te merken voordelen nemen, die worden genoten uit niet in dienstbetrekking in",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        565.6,
        458.6,
        577.12
      ],
      "text": "de zin van de WAO verrichte werkzaamheden en diensten. Onder het verrichten van",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        585.16,
        481.95,
        596.68
      ],
      "text": "werkzaamheden verstaan wij ook het houden van kostgangers en het productief maken of",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        604.6,
        457.56,
        616.12
      ],
      "text": "vervreemden van een auteursrecht of een octrooi door de auteur of de uitvinder zelf.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        633.36,
        317.56,
        646.92
      ],
      "text": "Inkomsten uit (onder)verhuur/kostgangers",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        654.67,
        494.73,
        666.19
      ],
      "text": "1 januari 1985 worden inkomsten uit onderverhuur aangemerkt als inkomsten uit vermogen.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        674.23,
        488.07,
        685.75
      ],
      "text": "Sindsdien geldt dus dat inkomsten uit onderverhuur (dit is het uitsluitend verhuren van een",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        693.67,
        512.79,
        705.19
      ],
      "text": "kamer/etage in de eigen woning) niet wordt aangemerkt als inkomen uit arbeid, maar inkomsten",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        713.23,
        500.5,
        724.75
      ],
      "text": "uit het houden van kostgangers (dat is iemand die een kamer huurt en voor wie de verhuurder",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        732.67,
        491.87,
        744.19
      ],
      "text": "maaltijden bereidt) wel. Onder bepaalde voorwaarden kan betrokkene er voor kiezen om de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        78.57,
        506.58,
        90.09
      ],
      "text": "inkomsten uit het houden van kostgangers aan te laten merken als inkomsten uit eigen woning.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        98.03,
        413.12,
        109.55
      ],
      "text": "Betrokkene moet deze keuze aangeven bij de aangifte inkomstenbelasting.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        126.79,
        252.79,
        140.35
      ],
      "text": "Rendabel maken van vermogen",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        148.07,
        512.94,
        159.59
      ],
      "text": "Vanaf 2001 wordt door de fiscus ook het rendabel maken van vermogen als resultaat uit overige",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        167.63,
        479.04,
        179.15
      ],
      "text": "werkzaamheden aangemerkt (vraag 11 van het aangiftebiljet). Het gaat hierbij om het ter",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        187.07,
        509.41,
        198.59
      ],
      "text": "beschikking stellen van vermogen aan (rechts)personen waarmee betrokkene op enigerlei wijze",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        206.63,
        132.82,
        218.15
      ],
      "text": "verbonden is.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        226.07,
        516.67,
        237.59
      ],
      "text": "Aangezien het hier niet gaat om het verrichten van arbeid, worden deze inkomsten voor de WAZ",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        245.63,
        331.6,
        257.15
      ],
      "text": "niet aangemerkt als inkomsten uit tegenwoordige arbeid.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        265.07,
        183.5,
        276.59
      ],
      "text": "1 lid 1 onderdeel l WAZ",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        293.69,
        187.45,
        308.69
      ],
      "text": "Verwervingskosten",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        324.38,
        518.35,
        335.9
      ],
      "text": "Een beroepsbeoefenaar kon tot 2001 verwervingskosten op zijn inkomsten in mindering brengen.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        343.94,
        505.9,
        355.46
      ],
      "text": "Aftrekbare kosten zoals bedoeld in de belastingwetgeving zijn de kosten die iemand maakt om",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        363.38,
        515.9,
        374.9
      ],
      "text": "zijn inkomen te verwerven, te innen en te behouden, daaronder begrepen de op het loon rustende",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        382.94,
        459.92,
        394.46
      ],
      "text": "lasten en afschrijvingen op goederen die tot het verwerven van de inkomsten dienen.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        402.38,
        512.67,
        413.9
      ],
      "text": "De voor rekening van betrokkene komende kosten van reizen tussen woon en werkplaats en van",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        421.94,
        432.63,
        433.46
      ],
      "text": "verzekering van goederen moet je ook als kosten van verwerving beschouwen.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        441.38,
        517.96,
        452.9
      ],
      "text": "Overigens houdt dit wel in, dat de vaste aftrekbedragen (forfaits) zoals de belastingwetgeving die",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        460.94,
        516.73,
        472.46
      ],
      "text": "kende, van toepassing zijn. Dit houdt in, dat zonder werkelijke kosten te hoeven aantonen, er een",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        480.4,
        521.48,
        491.92
      ],
      "text": "bepaald bedrag mag worden afgetrokken. Mochten de kosten aantoonbaar hoger liggen, dan is dat",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        499.96,
        188.69,
        511.48
      ],
      "text": "hogere bedrag aftrekbaar.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        519.4,
        497.63,
        530.92
      ],
      "text": "Vanaf 2001 is de aftrek van de verwervingskosten vervallen. Ook het beroepskostenforfait is",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        538.96,
        500.14,
        550.48
      ],
      "text": "vervallen. Dit bedroeg in 2000 12% van het loon uit tegenwoordige dienstbetrekking met een",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        558.4,
        518.76,
        569.92
      ],
      "text": "maximum van ƒ 1073. Betrokkene kan alleen nog gebruik maken van het reiskostenforfait woon-",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        577.96,
        315.22,
        589.48
      ],
      "text": "werkverkeer en de zeedagenaftrek voor zeevarenden.",
      "source": "text"
    }
  ]
}
