  "pdf_url": "https://www.uwv.nl/assets-kai/files/baaa2081-1d72-4f14-81ff-a5eba6636d5e/bijlage-1-de-beroepsbeoefenaar.pdf",
  "publication_title": "Besluit Woo-verzoek inkomen beroepsbeoefenaren bij WAZ",
  "publication_date": "2023-05-09T00:00:00Z",
  "publication_type": "WOO publicatie",
  "pdf_label": "Bijlage 1 De beroepsbeoefenaar (PDF, 430 kB)",
  "retrieved_at": "2026-06-30T13:21:52+00:00",
