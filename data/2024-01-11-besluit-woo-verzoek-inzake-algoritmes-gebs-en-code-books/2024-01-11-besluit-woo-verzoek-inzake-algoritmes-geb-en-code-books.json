        71.64,
        295.96,
        301.16,
        304.0
      ],
      "text": "Beslissing op uw verzoek om informatie d.d. 10-11-2023",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
