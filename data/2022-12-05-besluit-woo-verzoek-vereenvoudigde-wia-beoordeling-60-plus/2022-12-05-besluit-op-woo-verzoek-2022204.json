      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        548.65,
        130.83,
        557.65
      ],
      "text": "documenten:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        76.58,
        568.93,
        448.9,
        577.93
      ],
      "text": "Nr. Documentnaam Beoordeling",
      "source": "text"
    },
    {
