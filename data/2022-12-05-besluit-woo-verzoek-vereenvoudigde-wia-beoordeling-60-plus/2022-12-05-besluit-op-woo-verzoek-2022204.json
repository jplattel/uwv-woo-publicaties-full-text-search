      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        415.67,
        515.67,
        424.67
      ],
      "text": "UWV heeft besloten de aangetroffen documenten met de door u verzochte informatie openbaar te",
      "source": "text"
    },
