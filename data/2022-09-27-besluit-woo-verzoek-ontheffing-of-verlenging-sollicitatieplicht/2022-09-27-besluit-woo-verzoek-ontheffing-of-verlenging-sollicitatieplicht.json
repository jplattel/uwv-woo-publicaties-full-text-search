      "type": "heading",
      "page": 1,
      "bbox": [
        186.0,
        1431.0,
        1403.0,
        1458.0
      ],
      "text": "neergelegd in documenten wilt u ontvangen per UWV-vestiging over de periode van januari 2017",
      "source": "ocr"
