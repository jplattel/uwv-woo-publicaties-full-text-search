      "bbox": [
        71.3,
        294.87,
        300.84,
        302.91
      ],
      "text": "Beslissing op uw verzoek om informatie d.d. 26-10-2023",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        412.18,
        306.81,
