      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        434.39,
        487.29,
        443.39
      ],
      "text": "UWV heeft besloten om een overzicht van de STAP-aanvragen van alle vier de tranches, als",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
