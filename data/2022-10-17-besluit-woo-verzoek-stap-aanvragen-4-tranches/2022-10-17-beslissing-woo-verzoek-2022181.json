      "bbox": [
        88.82,
        587.53,
        205.48,
        596.53
      ],
      "text": "- aangevraagde budget",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        620.41,
        208.2,
        629.41
      ],
