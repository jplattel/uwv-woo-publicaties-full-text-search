{
  "source_id": "2022-10-27-besluit-woo-verzoek-inzake-regreszaken/2022-10-27-bijlage1-beleid-uwv-regres-wel-of-niet-aansprakelijk-stellen",
  "publication_slug": "2022-10-27-besluit-woo-verzoek-inzake-regreszaken",
  "pdf_slug": "2022-10-27-bijlage1-beleid-uwv-regres-wel-of-niet-aansprakelijk-stellen",
  "source_page_url": "https://www.uwv.nl/nl/wet-open-overheid/woo-publicaties/2022/besluit-woo-verzoek-inzake-regreszaken",
  "pdf_url": "https://www.uwv.nl/assets-kai/files/acbde05f-9942-498d-b6c7-ded4791c16c6/bijlage1-beleid-uwv-regres-wel-of-niet-aansprakelijk-stellen.pdf",
  "publication_title": "Besluit Woo-verzoek inzake regreszaken",
  "publication_date": "2022-10-27T00:00:00Z",
  "publication_type": "WOO publicatie",
  "pdf_label": "Bijlage 1 Beleid UWV regres wel of niet aansprakelijk stellen (PDF, 100 kB)",
  "retrieved_at": "2026-06-30T14:01:19+00:00",
  "sha256": "5f5a010e250415f0e03f7e16667a27336617c6ef0af4aeea4fca06f147a1a0bf",
  "page_count": 2,
  "ocr_used": false,
  "blocks": [
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        73.65,
        322.09,
        82.65
      ],
      "text": "Uitgangspunten UWV bij de uitvoering van regres",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.81,
        98.85,
        253.29,
        107.85
      ],
      "text": "Bevoegdheid om regres in te stellen",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.81,
        111.45,
        524.58,
        120.45
      ],
      "text": "De wetgever biedt UWV in de sociale zekerheidswetgeving de mogelijkheid om regres in te stellen",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        124.05,
        524.44,
        133.05
      ],
      "text": "als de arbeidsongeschiktheid door een derde is veroorzaakt. De wetgever heeft daarbij gekozen voor",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        136.65,
        524.49,
        145.65
      ],
      "text": "een autonome bevoegdheid van UWV om regres in te stellen, niet voor een wettelijke verplichting",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        149.13,
        524.45,
        158.13
      ],
      "text": "voor UWV om regres in te stellen. Daarmee laat de wetgever de afweging om wel of geen regres in",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        161.73,
        524.38,
        170.73
      ],
      "text": "te stellen, waaronder begrepen de afweging om na het instellen van regres alsnog van regres af te",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        174.33,
        524.36,
        183.33
      ],
      "text": "zien, over aan UWV. Dat heeft er toe geleid dat UWV onderstaande uitgangspunten heeft",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        186.93,
        524.56,
        195.93
      ],
      "text": "geformuleerd die bij die afweging om al dan geen regres in te stellen als richtlijn worden gehanteerd.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.79,
        212.01,
        166.51,
        221.01
      ],
      "text": "Wel of geen regres",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.79,
        224.61,
        524.5,
        233.61
      ],
      "text": "De afweging van UWV om al dan geen regres in te stellen dan wel om een eenmaal ingezette",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        237.21,
        524.39,
        246.21
      ],
      "text": "regresactie niet te continueren wordt gebaseerd op een kostenbatenanalyse en een juridische",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        249.81,
        171.52,
        258.81
      ],
      "text": "haalbaarheidsanalyse.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        275.01,
        173.25,
        284.01
      ],
      "text": "Kostenbatenanalyse",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        287.5,
        524.45,
        296.5
      ],
      "text": "In situaties waar de verwachting is dat de kosten van instellen dan wel continueren van regres niet",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.78,
        300.1,
        524.57,
        309.1
      ],
      "text": "opwegen tegen de mogelijke (regres)baten, stelt UWV geen regres in respectievelijk beëindigt UWV",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.79,
        312.7,
        380.92,
        321.7
      ],
      "text": "haar reeds ingezette regresactie. Dat doet zich onder meer voor bij:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.79,
        337.9,
        524.54,
        346.9
      ],
      "text": "1) afgesloten ZW-uitkeringen met een gering financieel belang waartegen geen bezwaar is",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.79,
        350.38,
        309.79,
        359.38
      ],
      "text": "ingediend en dus geen WIA/IVA op de ZW volgt;",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        375.58,
        524.49,
        384.58
      ],
      "text": "2) molestzaken: molest wordt niet gedekt door verzekeraars. Daardoor moet de veroorzaker de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.8,
        388.18,
        524.48,
        397.18
      ],
      "text": "schade uit eigen middelen financieren. Die middelen zijn veelal beperkt waardoor de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.8,
        400.78,
        524.49,
        409.78
      ],
      "text": "regresopbrengst eveneens zeer beperkt is. Bij molestzaken staat de uiteindelijke",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.8,
        413.38,
        524.55,
        422.38
      ],
      "text": "regresopbrengst, mocht die er al zijn, daarom veelal niet in verhouding tot de behandelkosten",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.78,
        425.86,
        524.46,
        434.86
      ],
      "text": "van UWV. Gesteld dat de identiteit van de veroorzaker bekend is en de aansprakelijkheid",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.77,
        438.46,
        524.44,
        447.46
      ],
      "text": "aangetoond kan worden, dan dringt de vraag zich op of de veroorzaker over voldoende financiële",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.76,
        451.06,
        524.43,
        460.06
      ],
      "text": "middelen beschikt om de regresvordering van UWV binnen afzienbare tijd te kunnen voldoen.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.76,
        463.66,
        524.42,
        472.66
      ],
      "text": "Naast het onderzoek naar de identiteit van de veroorzaker, strekken de behandelkosten van UWV",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.76,
        476.26,
        524.48,
        485.26
      ],
      "text": "zich in de meeste gevallen daarom ook uit tot een onderzoek naar de solvabiliteit van de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.77,
        488.86,
        524.45,
        497.86
      ],
      "text": "veroorzaker. Die solvabiliteit ontbreekt vaak. Het best te bereiken resultaat is dan een met de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.77,
        501.35,
        524.38,
        510.35
      ],
      "text": "veroorzaker af te spreken minnelijke betalingsregeling, meestal lopend over een lange periode,",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.76,
        513.95,
        524.43,
        522.95
      ],
      "text": "waarvan UWV een langdurige administratie moet bijhouden. Bij molestzaken wordt de hoofdsom",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.76,
        526.55,
        524.55,
        535.55
      ],
      "text": "van de regresvordering van UWV slechts zelden (nooit) binnen afzienbare tijd voldaan, laat staan",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.76,
        539.15,
        142.81,
        548.15
      ],
      "text": "in één keer.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.76,
        564.23,
        524.46,
        573.23
      ],
      "text": "Los van dit kosten-/batenargument kan UWV bij molestzaken wegens onder meer de volgende",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.76,
        576.83,
        524.34,
        585.83
      ],
      "text": "factoren tot de afweging komen om geen regres in te stellen dan wel om een reeds ingezette",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.77,
        589.43,
        207.6,
        598.43
      ],
      "text": "regresactie te beëindigen:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.77,
        613.88,
        92.91,
        622.88
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        106.77,
        614.63,
        524.45,
        623.63
      ],
      "text": "voor kansrijk regres is de medewerking van de UWV-verzekerde nodig: UWV moet jegens de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        106.78,
        627.23,
        524.39,
        636.23
      ],
      "text": "aansprakelijk te stellen persoon aantonen dat de uitkering/voorziening van de UWV-",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        106.78,
        639.71,
        524.53,
        648.71
      ],
      "text": "verzekerde in medisch causaal verband staat met het voorval. Om dat vast te stellen is UWV",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        106.77,
        652.31,
        524.48,
        661.31
      ],
      "text": "veelal aangewezen op een door een onafhankelijke medicus op te stellen medische expertise.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        106.78,
        664.91,
        524.35,
        673.91
      ],
      "text": "Daartoe is UWV afhankelijk van de medewerking van de UWV-verzekerde. Op die",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        106.78,
        677.51,
        524.47,
        686.51
      ],
      "text": "medewerking hoeft UWV doorgaans niet te rekenen omdat verzekerde dan weer ten volle",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        106.78,
        690.11,
        524.48,
        699.11
      ],
      "text": "met het molestincident wordt geconfronteerd zonder daar zelf enig (financieel) belang bij te",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        106.78,
        702.71,
        524.46,
        711.71
      ],
      "text": "hebben. De medische expertise dient immers enkel het belang van UWV, namelijk mogelijke",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        106.78,
        715.19,
        524.49,
        724.19
      ],
      "text": "inning van regresinkomsten. UWV-verzekerden hebben jegens UWV geen wettelijke",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        106.78,
        727.79,
        524.52,
        736.79
      ],
      "text": "medewerkingsplicht aan de uitvoering door UWV van haar regresrecht. UWV kan haar",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        106.79,
        740.39,
        524.43,
        749.39
      ],
      "text": "verzekerden zodoende niet verplichten tot medewerking aan een medische expertise. Een",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        106.77,
        752.99,
        524.46,
        761.99
      ],
      "text": "dergelijke medewerkingsplicht bestaat wel in het kader van particuliere",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        294.84,
        782.48,
        300.44,
        793.52
      ],
      "text": "1",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        106.8,
        73.65,
        524.51,
        82.65
      ],
      "text": "verzekeringsvoorwaarden zodat verzekerden jegens hun (commerciële) particuliere",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        106.8,
        86.25,
        524.35,
        95.25
      ],
      "text": "verzekeringsmaatschappij wel verplicht zijn om hun medewerking te verlenen aan verhaal",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        106.79,
        98.85,
        410.28,
        107.85
      ],
      "text": "door de (commerciële) particuliere verzekeraar op de veroorzaker;",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.79,
        123.3,
        92.93,
        132.3
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        106.79,
        124.05,
        524.53,
        133.05
      ],
      "text": "de veiligheid van de UWV-verzekerde behoort prioriteit te krijgen: doordat de veroorzaker",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        106.8,
        136.65,
        524.42,
        145.65
      ],
      "text": "de schade uit eigen financiële middelen moet betalen is de kans op represailles richting de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        106.8,
        149.13,
        524.48,
        158.13
      ],
      "text": "UWV-verzekerde reëel. UWV kan over aanwijzingen beschikken dat het instellen dan wel",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        106.81,
        161.73,
        524.47,
        170.73
      ],
      "text": "continueren van regres door UWV jegens de veroorzaker tot een bedreigende situatie bij de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        106.81,
        174.33,
        524.52,
        183.33
      ],
      "text": "UWV-verzekerde kan leiden. Uit dossiergegevens kan volgen dat die kans niet denkbeeldig",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        106.81,
        186.93,
        524.45,
        195.93
      ],
      "text": "is. Het komt eveneens voor dat de UWV-verzekerde UWV expliciet vraagt om geen regres in",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        106.8,
        199.53,
        524.47,
        208.53
      ],
      "text": "te stellen dan wel de reeds ingezette regresactie te staken wegens de mogelijkheid van",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        106.8,
        212.01,
        157.85,
        221.01
      ],
      "text": "bedreiging.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        237.21,
        235.41,
        246.21
      ],
      "text": "Juridische haalbaarheidsanalyse",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        249.81,
        524.41,
        258.81
      ],
      "text": "In situaties waar uit de juridische haalbaarheidsanalyse van UWV volgt dat succesvol regres niet",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        262.41,
        524.5,
        271.41
      ],
      "text": "mogelijk lijkt, stelt UWV geen regres in respectievelijk beëindigt UWV haar reeds ingezette",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        275.01,
        284.56,
        284.01
      ],
      "text": "regresactie. Dat doet zich onder meer voor bij:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.81,
        299.35,
        74.95,
        308.35
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.81,
        300.1,
        524.59,
        309.1
      ],
      "text": "het van toepassing zijn van de voor UWV geldende wettelijke regresbeperking inzake het geen",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.81,
        312.7,
        524.46,
        321.7
      ],
      "text": "regres kunnen nemen op de eigen formele/materiële werkgever van de UWV-verzekerde en/of",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.81,
        325.3,
        524.44,
        334.3
      ],
      "text": "de eigen formele/materiële collega van de UWV-verzekerde. Dat betekent dat UWV geen regres",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.82,
        337.9,
        524.53,
        346.9
      ],
      "text": "kan nemen in alle gevallen (dus zowel tijdens werktijd als tijdens privétijd) waarin een",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.82,
        350.38,
        524.5,
        359.38
      ],
      "text": "formele/materiële werkgever/collega van de UWV-verzekerde de arbeidsongeschiktheid heeft",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.81,
        362.98,
        146.66,
        371.98
      ],
      "text": "veroorzaakt;",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.81,
        387.43,
        74.95,
        396.43
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.81,
        388.18,
        524.36,
        397.18
      ],
      "text": "het van toepassing zijn van de voor UWV geldende wettelijke regresbeperking inzake de Tijdelijke",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.81,
        400.78,
        524.36,
        409.78
      ],
      "text": "Regeling Verhaalsrechten. Dat houdt in dat UWV wat betreft uitoefening van haar regresrecht",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.8,
        413.38,
        524.49,
        422.38
      ],
      "text": "geen beroep kan doen op de vele in het Nieuw Burgerlijk Wetboek in 1992 ingevoerde",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.8,
        425.86,
        278.05,
        434.86
      ],
      "text": "uitbreidingen van risicoaansprakelijkheid;",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.81,
        450.32,
        74.95,
        459.32
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.81,
        451.06,
        524.49,
        460.06
      ],
      "text": "het van toepassing zijn van een voor UWV geldende in de jurisprudentie ontwikkelde",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.81,
        463.66,
        524.47,
        472.66
      ],
      "text": "regresbeperking zoals het niet door UWV kunnen instellen van regres op de veroorzaker die een",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.81,
        476.26,
        380.25,
        485.26
      ],
      "text": "duurzaam samenlevingsverband voert met de UWV-verzekerde;",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.8,
        500.6,
        74.94,
        509.6
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.8,
        501.35,
        262.18,
        510.35
      ],
      "text": "eigen schuld van de UWV-verzekerde;",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.81,
        525.8,
        74.95,
        534.8
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.81,
        526.55,
        524.44,
        535.55
      ],
      "text": "het niet door UWV kunnen voldoen aan haar wettelijke bewijsplicht. In regreszaken is UWV",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.8,
        539.15,
        524.5,
        548.15
      ],
      "text": "eisende partij. Dat houdt in dat de bewijslast van een onrechtmatige daad, zijnde de grondslag",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.79,
        551.75,
        524.45,
        560.75
      ],
      "text": "van bijna alle regreszaken, bij UWV ligt. Het is dientengevolge aan UWV om in al die regreszaken",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.78,
        564.23,
        524.3,
        573.23
      ],
      "text": "te bewijzen dat de tegenpartij daadwerkelijk verwijtbaar heeft gehandeld. Aanvullend zal UWV",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.77,
        576.83,
        524.45,
        585.83
      ],
      "text": "ook moeten bewijzen of de door UWV verstrekte uitkering/voorziening in juridisch en/of medisch",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.77,
        589.43,
        524.45,
        598.43
      ],
      "text": "causaal verband staat met het ongeval. UWV is niet in alle regreszaken in staat aan die juridische",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.76,
        602.03,
        524.46,
        611.03
      ],
      "text": "en medisch causale bewijsplicht te voldoen. Bijkomende omstandigheid is dat UWV wat die",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.77,
        614.63,
        524.44,
        623.63
      ],
      "text": "bewijslast betreft afhankelijk kan zijn van de medewerking van de UWV-verzekerde en/of van",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.77,
        627.23,
        524.42,
        636.23
      ],
      "text": "getuigen. Die medewerking zal UWV doorgaans niet krijgen. UWV-verzekerden en getuigen",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.76,
        639.71,
        524.45,
        648.71
      ],
      "text": "hebben jegens UWV geen medewerkingsplicht aan de uitvoering door UWV van haar regresrecht",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.77,
        652.31,
        524.52,
        661.31
      ],
      "text": "en dientengevolge ook geen medewerkingsplicht aan het leveren van door UWV benodigd bewijs",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.77,
        664.91,
        291.09,
        673.91
      ],
      "text": "om haar regresvordering te gelde te maken;",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.76,
        689.36,
        74.9,
        698.36
      ],
      "text": "•",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.76,
        690.11,
        241.55,
        699.11
      ],
      "text": "verjaring van de regresvordering.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        294.84,
        782.48,
        300.44,
        793.52
      ],
      "text": "2",
      "source": "text"
    }
  ]
}
