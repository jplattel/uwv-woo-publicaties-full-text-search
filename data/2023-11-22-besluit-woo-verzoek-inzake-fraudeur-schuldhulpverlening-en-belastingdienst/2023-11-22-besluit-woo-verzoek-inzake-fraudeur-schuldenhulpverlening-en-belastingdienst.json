      "bbox": [
        71.64,
        295.96,
        295.99,
        304.0
      ],
      "text": "Beslissing op uw verzoek om informatie d.d. 2-10-2023",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
