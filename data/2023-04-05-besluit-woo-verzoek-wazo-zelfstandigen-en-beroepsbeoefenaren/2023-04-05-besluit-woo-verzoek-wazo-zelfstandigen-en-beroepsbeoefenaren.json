      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        584.0,
        405.18,
        593.0
      ],
      "text": "door u gevraagde informatie. De volgende documenten zijn aangetroffen.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        76.56,
        604.29,
        448.85,
        613.29
      ],
      "text": "Nr. Documentnaam Beoordeling",
      "source": "text"
    },
