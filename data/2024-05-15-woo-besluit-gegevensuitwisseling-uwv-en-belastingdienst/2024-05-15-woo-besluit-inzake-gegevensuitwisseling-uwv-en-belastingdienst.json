      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        306.95,
        226.54,
        315.95
      ],
      "text": "Niet eens met deze beslissing?",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
