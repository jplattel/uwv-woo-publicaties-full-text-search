    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        218.0,
        542.0,
        1468.0,
        567.0
      ],
      "text": "Het is daarentegen wel aan de betreffende klanten toegestaan om inzage te verkrijgen in hun eigen",
