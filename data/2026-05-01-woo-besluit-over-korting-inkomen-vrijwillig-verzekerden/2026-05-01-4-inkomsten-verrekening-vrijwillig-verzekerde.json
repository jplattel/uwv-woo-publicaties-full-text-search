      "bbox": [
        74.25,
        442.5,
        506.1,
        453.75
      ],
      "text": "Overzicht Systemen UWV",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        429.37,
        462.0,
        517.73,
        473.25
      ],
      "text": "Wijzigingshistorie",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        74.25,
        482.25,
        276.08,
