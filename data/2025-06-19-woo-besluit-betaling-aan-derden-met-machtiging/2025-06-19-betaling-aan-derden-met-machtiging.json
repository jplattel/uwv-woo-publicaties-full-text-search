{
  "source_id": "2025-06-19-woo-besluit-betaling-aan-derden-met-machtiging/2025-06-19-betaling-aan-derden-met-machtiging",
  "publication_slug": "2025-06-19-woo-besluit-betaling-aan-derden-met-machtiging",
