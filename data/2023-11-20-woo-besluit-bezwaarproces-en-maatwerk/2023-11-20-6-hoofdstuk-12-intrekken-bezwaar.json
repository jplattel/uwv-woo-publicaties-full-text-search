  "pdf_url": "https://www.uwv.nl/assets-kai/files/fd413c51-9893-4312-adb7-73ecc804414e/6-hoofdstuk-12-intrekken-bezwaar.pdf",
  "publication_title": "Woo-besluit Bezwaarproces en maatwerk",
