{
  "source_id": "2023-11-20-woo-besluit-bezwaarproces-en-maatwerk/2023-11-20-6-hoofdstuk-06d-opvragen-gegevens-bij-behandelend-sector",
  "publication_slug": "2023-11-20-woo-besluit-bezwaarproces-en-maatwerk",
