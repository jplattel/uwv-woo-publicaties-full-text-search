  "source_page_url": "https://www.uwv.nl/nl/wet-open-overheid/woo-publicaties/2023/woo-besluit-bezwaarproces-en-maatwerk",
  "pdf_url": "https://www.uwv.nl/assets-kai/files/757b9262-707a-4f8f-b5a1-184bdc236d7b/6-hoofdstuk-06d-opvragen-gegevens-bij-behandelend-sector.pdf",
  "publication_title": "Woo-besluit Bezwaarproces en maatwerk",
