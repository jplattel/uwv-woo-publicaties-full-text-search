      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        106.8,
        579.32,
        405.15,
        588.32
      ],
      "text": "Het WAZO-dagloon ten opzichte van het WW-dagloon (2024101),",
      "source": "text"
