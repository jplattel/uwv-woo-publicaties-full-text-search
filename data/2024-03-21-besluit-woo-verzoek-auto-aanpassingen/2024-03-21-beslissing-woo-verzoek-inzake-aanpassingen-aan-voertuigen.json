      "page": 1,
      "bbox": [
        76.58,
        755.08,
        465.7,
        764.08
      ],
      "text": "1. Woo aanpasbedrijven CRV Deels openbaar",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        76.58,
        130.04,
        458.95,
        139.04
      ],
