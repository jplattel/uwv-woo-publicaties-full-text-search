      "type": "paragraph",
      "page": 1,
      "bbox": [
        221.0,
        1534.0,
        1086.0,
        1561.0
      ],
      "text": "aantal positieve adviezen was dat op basis van een pga toets is gegeven.",
      "source": "ocr"
    },
