      "type": "paragraph",
      "page": 4,
      "bbox": [
        74.25,
        782.25,
        705.61,
        793.5
      ],
      "text": "Intern Eventueel e-mail naar 1 van de AW-samenloopteams",
      "source": "text"
    },
    {
      "type": "heading",
      "page": 4,
