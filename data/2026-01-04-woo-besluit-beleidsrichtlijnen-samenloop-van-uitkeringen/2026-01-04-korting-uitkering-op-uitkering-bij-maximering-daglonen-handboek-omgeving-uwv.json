    },
    {
      "type": "paragraph",
      "page": 4,
      "bbox": [
        89.25,
        61.5,
        393.91,
        72.75
      ],
      "text": "<Datum begin>: de vastgestelde‘ datum vervallen samenloop’",
      "source": "text"
    },
    {
      "type": "heading",
      "page": 4,
      "bbox": [
        76.5,
        77.25,
        82.57,
        95.25
      ],
      "text": "•",
      "source": "text"
    },
