      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        228.91,
        514.55,
        237.91
      ],
      "text": "onder een uitzonderinggrond van de Woo valt. Daarom wordt besloten het document openbaar te",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        239.83,
        104.58,
        248.83
      ],
