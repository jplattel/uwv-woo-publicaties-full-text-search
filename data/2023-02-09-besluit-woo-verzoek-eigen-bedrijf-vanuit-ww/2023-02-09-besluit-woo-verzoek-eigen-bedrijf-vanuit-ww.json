      "type": "paragraph",
      "page": 2,
      "bbox": [
        88.82,
        249.92,
        503.02,
        258.92
      ],
      "text": "5. wetten.nl - Regeling - Protocol Voorzieningen UWV 2021 - BWBR0046028 (overheid.nl)",
