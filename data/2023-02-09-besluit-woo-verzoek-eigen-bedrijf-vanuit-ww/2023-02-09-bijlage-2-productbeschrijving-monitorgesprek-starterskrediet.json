      "page": 2,
      "bbox": [
        318.91,
        287.15,
        538.2,
        296.15
      ],
      "text": "de betaaltermijnen wil aanpassen. De plausibele",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        318.91,
        303.59,
        457.13,
        312.59
      ],
      "text": "verklaring heeft te maken met",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        318.91,
        320.03,
        454.32,
        329.03
      ],
      "text": "bedrijfseconomische redenen.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        318.91,
        336.35,
        536.67,
        345.35
      ],
      "text": "De UWV-professional zal hierbij een overweging",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        318.91,
        352.79,
        501.09,
        361.79
      ],
      "text": "moeten maken of het aanpassen van de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        318.91,
        369.23,
        537.45,
        378.23
      ],
      "text": "betalingsregeling de beste oplossing is. Mogelijk",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        318.91,
        385.67,
        487.24,
        394.67
      ],
      "text": "is het beëindigen van de zelfstandige",
      "source": "text"
    },
