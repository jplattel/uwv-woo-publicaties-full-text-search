    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        318.91,
        434.87,
        528.92,
        443.87
      ],
      "text": "professional kan de klant geen bindend advies",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        318.91,
        451.21,
        530.52,
        460.21
      ],
      "text": "geven over het beëindigen van de zelfstandige",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        318.91,
        467.65,
        395.99,
        476.65
      ],
      "text": "werkzaamheden.",
      "source": "text"
    },
    {
