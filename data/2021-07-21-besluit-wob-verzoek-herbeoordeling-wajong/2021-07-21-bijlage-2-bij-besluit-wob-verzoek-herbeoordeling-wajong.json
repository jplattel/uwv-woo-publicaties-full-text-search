      ],
      "text": "",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        104.04,
        745.94,
        517.91,
        754.94
      ],
      "text": "Zowel op grond van praktijkervaringen als op grond van beperkte onderzoekgegevens gold",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        92.04,
        747.51,
        97.28,
        754.53
      ],
      "text": "",
