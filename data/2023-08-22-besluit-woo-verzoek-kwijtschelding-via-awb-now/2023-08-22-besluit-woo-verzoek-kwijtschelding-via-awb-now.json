    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        71.3,
        294.87,
        300.84,
        302.91
      ],
      "text": "Beslissing op uw verzoek om informatie d.d. 07-07-2023",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        412.18,
        305.07,
        415.83,
