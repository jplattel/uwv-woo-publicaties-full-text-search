      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        547.26,
        408.67,
        556.26
      ],
      "text": "gegevensbeschermingseffectbeoordelingen en overige juridische analyses.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        569.1,
