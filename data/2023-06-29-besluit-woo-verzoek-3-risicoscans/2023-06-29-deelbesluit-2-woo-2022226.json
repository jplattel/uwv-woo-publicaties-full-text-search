    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        416.01,
        486.48,
        425.01
      ],
      "text": "UWV heeft besloten de door u opgevraagde gegevens voor zover aanwezig (deels) aan u te",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        426.92,
        127.72,
        435.92
      ],
