  "source_page_url": "https://www.uwv.nl/nl/wet-open-overheid/woo-publicaties/2022/besluit-woo-verzoek-omtrent-rechtzaken-gehoord-worden-en-rechterlijke-uitspraken",
  "pdf_url": "https://www.uwv.nl/assets-kai/files/237d7770-b0da-4ed1-b70b-90dcce29644a/bijlage-10-hoofdstuk-07-horen-versie-2010-11-01.pdf",
  "publication_title": "Besluit Woo-verzoek omtrent rechtzaken, gehoord worden en rechterlijke uitspraken",
  "publication_date": "2022-11-02T00:00:00Z",
  "publication_type": "WOO publicatie",
  "pdf_label": "Bijlage 10 Hoofdstuk 07 horen (PDF, 141 kB)",
  "retrieved_at": "2026-06-30T13:54:08+00:00",
  "sha256": "fdbe5382b82d701cedd68333d9392ef5d101e1c8005dd48ff56da99e181c1ade",
  "page_count": 2,
  "ocr_used": false,
  "blocks": [
    {
      "type": "heading",
      "page": 1,
      "bbox": [
        72.02,
        86.2,
        195.9,
        96.16
      ],
      "text": "HOOFDSTUK 7 HOREN",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        114.2,
        545.11,
        123.2
      ],
      "text": "Aan het begin van de bezwaarschriftprocedure vindt een telefonisch contact plaats met belanghebbende",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        126.2,
        529.08,
        135.2
      ],
      "text": "of diens gemachtigde. Tijdens het telefoongesprek wordt met de belanghebbende het bezwaarschrift",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        138.2,
        540.19,
        147.2
      ],
      "text": "besproken, met als doel een beter inzicht te krijgen in de reden van het indienen van het bezwaar. Dat",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        150.2,
        540.49,
        159.2
      ],
      "text": "betekent echter niet dat het telefonisch contact beschouwd kan worden als een telefonische hoorzitting",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        162.2,
        546.05,
        171.2
      ],
      "text": "(CRvB 15-04-03, RSV 2003/155). Als tijdens dit gesprek duidelijk wordt dat de bezwaarschriftprocedure",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        174.2,
        548.75,
        183.2
      ],
      "text": "zal worden voortgezet, wordt dan ook uitdrukkelijk gevraagd of belanghebbende gehoord wil worden. De",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        186.2,
        514.53,
        195.2
      ],
      "text": "verklaring van belanghebbende over het al dan niet gehoord willen worden, wordt niet schriftelijk",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        198.2,
        531.07,
        207.2
      ],
      "text": "bevestigd, maar wordt opgenomen in het verslag van het telefonisch contact (AB 2003/81). Als geen",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        210.2,
        532.75,
        219.2
      ],
      "text": "hoorzitting wordt gehouden, wordt in de beslissing op bezwaar gemotiveerd waarom van het horen is",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        222.2,
        228.56,
        231.2
      ],
      "text": "afgezien (artikel 7:12, lid 1, Awb).",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        246.23,
        549.16,
        255.23
      ],
      "text": "Ook andere telefonische contacten, bijvoorbeeld het contact over de planning van de hoorzitting, kunnen",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        258.23,
        526.69,
        267.23
      ],
      "text": "niet als telefonisch horen worden gezien, ook niet als de bezwaargronden uitgebreid besproken zijn.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        282.23,
        534.48,
        291.23
      ],
      "text": "Met de klant of gemachtigde kan een telefonische hoorzitting worden afgesproken. Ook als meerdere",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        294.23,
        470.73,
        303.23
      ],
      "text": "belanghebbenden gehoord moeten worden, is telefonisch horen niet uitgesloten. Omdat",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        306.23,
        545.62,
        315.23
      ],
      "text": "belanghebbenden op grond van artikel 7:6, lid 1, Awb in elkaars aanwezigheid moeten worden gehoord,",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        318.23,
        535.25,
        327.23
      ],
      "text": "dient het telefonisch horen dan wel met behulp van een vergadertelefoon plaats te vinden. Ook als de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        330.23,
        494.4,
        339.23
      ],
      "text": "belanghebbende telefonisch wordt gehoord, zijn bij het horen in beginsel een hoorder en een",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        342.23,
        523.21,
        351.23
      ],
      "text": "verslaglegger aanwezig en dient op de gebruikelijke wijze een verslag van de hoorzitting te worden",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        354.23,
        248.37,
        363.23
      ],
      "text": "opgesteld (artikel 13 UWV-reglement).",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        378.23,
        252.31,
        387.23
      ],
      "text": "Uitgangspunten voor de hoorzitting",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        90.02,
        390.23,
        547.21,
        399.23
      ],
      "text": "De met belanghebbende telefonisch afgesproken datum en tijd van de hoorzitting worden schriftelijk",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        390.31,
        76.16,
        399.31
      ],
      "text": "",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        90.02,
        402.23,
        540.98,
        411.23
      ],
      "text": "bevestigd. Als belanghebbende telefonisch onbereikbaar is, terwijl hij heeft aangegeven gehoord te",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        90.02,
        414.25,
        501.92,
        423.25
      ],
      "text": "willen worden, wordt de hoorzitting eenzijdig door UWV gepland en wordt belanghebbende",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        90.02,
        426.25,
        285.39,
        435.25
      ],
      "text": "schriftelijk uitgenodigd voor de hoorzitting.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        90.02,
        437.17,
        228.79,
        446.17
      ],
      "text": "de hoorzitting is niet openbaar",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        437.25,
        76.16,
        446.25
      ],
      "text": "",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        90.02,
        448.09,
        530.2,
        457.09
      ],
      "text": "Belanghebbenden kunnen onder opgaaf van redenen verzoeken anderen de hoorzitting geheel of",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        448.17,
        76.16,
        457.17
      ],
      "text": "",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        90.02,
        459.13,
        436.34,
        468.13
      ],
      "text": "gedeeltelijk te laten bijwonen; op dit verzoek wordt zo snel mogelijk beslist.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        470.05,
        519.32,
        479.13
      ],
      "text": " Bij de hoorzitting kan op verzoek van belanghebbenden of op aanwijzing van het UWV gebruik",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        90.02,
        480.97,
        546.46,
        489.97
      ],
      "text": "worden gemaakt van een tolk; als het verzoek van belanghebbende wordt ingewilligd of het UWV de",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        90.02,
        491.89,
        545.65,
        500.89
      ],
      "text": "aanwezigheid van een tolk aangewezen acht, zorgt het UWV voor de beschikbaarheid en vergoeding",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        90.02,
        502.81,
        140.56,
        511.81
      ],
      "text": "van de tolk",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        93.14,
        513.73,
        539.12,
        522.73
      ],
      "text": "Meerdere belanghebbenden worden in beginsel in elkaars aanwezigheid gehoord (artikel 7:6 Awb)",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        513.81,
        76.16,
        522.81
      ],
      "text": "",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        536.65,
        168.75,
        545.65
      ],
      "text": "Verslag hoorzitting",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        550.69,
        533.35,
        559.69
      ],
      "text": "Tijdens de hoorzitting wordt aantekening gehouden van hetgeen over en weer wordt gezegd, dan wel",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        561.61,
        515.23,
        570.61
      ],
      "text": "wordt een opname gemaakt. De aantekeningen c.q. opname worden in ieder geval uitgewerkt als",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        572.56,
        537.63,
        581.56
      ],
      "text": "belanghebbende verzoekt om toezending van het verslag of als beroep is ingesteld tegen de beslissing",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        583.48,
        127.25,
        592.48
      ],
      "text": "op bezwaar.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        605.32,
        127.67,
        614.32
      ],
      "text": "Het verslag:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        616.36,
        384.28,
        625.36
      ],
      "text": "- vermeldt de namen van de aanwezigen en hun hoedanigheid",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        627.28,
        547.05,
        636.28
      ],
      "text": "- vermeldt kort al hetgeen over en weer is gezegd en relevante zaken die verder zijn voorgevallen",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        638.2,
        355.85,
        647.2
      ],
      "text": "- verwijst naar de stukken die ter zitting zijn overgelegd",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        649.12,
        278.02,
        658.12
      ],
      "text": "- wordt ondertekend door de voorzitter",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        660.04,
        390.21,
        669.04
      ],
      "text": "- wordt op verzoek kosteloos aan belanghebbende toegezonden",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        72.02,
        788.74,
        552.07,
        796.78
      ],
      "text": "Hoofdstuk 7 UWV-richtlijnen bezwaarproces, Horen, versie 1 november 2010 1",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        72.02,
        75.06,
        163.59,
        84.06
      ],
      "text": "Uitstel hoorzitting",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        72.02,
        87.08,
        543.72,
        96.08
      ],
      "text": "Als de belanghebbende of diens gemachtigde verzoekt om een geplande hoorzitting uit te stellen, wordt",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        72.02,
        99.08,
        216.21,
        108.08
      ],
      "text": "dit verzoek met hem besproken",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        72.02,
        123.08,
        127.98,
        132.08
      ],
      "text": "Toelichting",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        72.02,
        135.08,
        548.33,
        144.08
      ],
      "text": "Als het verzoek om de hoorzitting uit te stellen wordt gedaan door een belanghebbende die zich niet laat",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        72.02,
        147.08,
        527.88,
        156.08
      ],
      "text": "vertegenwoordigen of door een gemachtigde die geen professioneel rechtshulpverlener is, wordt het",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        72.02,
        159.08,
        543.22,
        168.08
      ],
      "text": "verzoek met de belanghebbende of diens gemachtigde besproken. Tijdens dat overleg kunnen de reden",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        72.02,
        171.08,
        548.12,
        180.08
      ],
      "text": "voor het uitstel en de gevolgen van het uitstel voor de afhandelingsduur van de bezwaarschriftprocedure",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        72.02,
        183.08,
        523.43,
        192.08
      ],
      "text": "aan de orde komen. Stelt de belanghebbende geen prijs op persoonlijk horen en heeft hij nog geen",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        72.02,
        195.08,
        493.94,
        204.08
      ],
      "text": "gemachtigde, dan kan hij worden gewezen op de mogelijkheid zich op de hoorzitting te laten",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        72.02,
        207.08,
        537.45,
        216.08
      ],
      "text": "vertegenwoordigen door een gemachtigde. Ook kan de mogelijkheid van telefonisch horen (nogmaals)",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        72.02,
        219.08,
        158.77,
        228.08
      ],
      "text": "worden besproken.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        72.02,
        788.74,
        552.07,
        796.78
      ],
      "text": "Hoofdstuk 7 UWV-richtlijnen bezwaarproces, Horen, versie 1 november 2010 2",
      "source": "text"
    }
  ]
}
