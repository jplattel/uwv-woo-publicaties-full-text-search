{
  "source_id": "2022-11-02-besluit-woo-verzoek-omtrent-rechtzaken-gehoord-worden-en-rechterlijke-uitspraken/2022-11-02-bijlage-10-hoofdstuk-07-horen-versie-2010-11-01",
  "publication_slug": "2022-11-02-besluit-woo-verzoek-omtrent-rechtzaken-gehoord-worden-en-rechterlijke-uitspraken",
