{
  "source_id": "2022-11-02-besluit-woo-verzoek-omtrent-rechtzaken-gehoord-worden-en-rechterlijke-uitspraken/2022-11-02-bijlage-11-hoofdstuk-08-afzien-van-horen-versie-2017-06-21",
  "publication_slug": "2022-11-02-besluit-woo-verzoek-omtrent-rechtzaken-gehoord-worden-en-rechterlijke-uitspraken",
