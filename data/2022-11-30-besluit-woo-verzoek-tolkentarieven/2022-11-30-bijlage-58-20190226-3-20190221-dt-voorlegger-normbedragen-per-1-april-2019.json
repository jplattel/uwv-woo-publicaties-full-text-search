    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        106.31,
        270.32,
        515.36,
        279.32
      ],
      "text": "huidige wijze van indexeren leidt tot wijziging van de ‘UWV-normbedragen” per 1 januari",
