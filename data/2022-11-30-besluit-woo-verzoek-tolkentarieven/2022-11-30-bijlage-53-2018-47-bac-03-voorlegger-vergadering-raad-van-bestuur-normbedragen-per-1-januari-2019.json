      "page": 1,
      "bbox": [
        178.0,
        1430.0,
        1515.0,
        1455.0
      ],
      "text": "o Bedragen die het wettelijk minimumloon volgen worden verhoogd met een factor 1,341. Het gaat om:",
      "source": "ocr"
