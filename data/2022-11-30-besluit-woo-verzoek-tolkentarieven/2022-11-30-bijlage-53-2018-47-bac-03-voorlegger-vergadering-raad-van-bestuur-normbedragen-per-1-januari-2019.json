      "type": "paragraph",
      "page": 1,
      "bbox": [
        179.0,
        1369.0,
        1167.0,
        1394.0
      ],
      "text": "worden vastgesteld. Het gaat om aanpassing van de volgende Normbedragen:",
      "source": "ocr"
