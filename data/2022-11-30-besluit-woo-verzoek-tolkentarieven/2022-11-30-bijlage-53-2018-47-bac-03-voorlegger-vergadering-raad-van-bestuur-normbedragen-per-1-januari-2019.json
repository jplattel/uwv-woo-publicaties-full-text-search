      "type": "paragraph",
      "page": 1,
      "bbox": [
        177.0,
        1246.0,
        1211.0,
        1272.0
      ],
      "text": "aanleiding toe is — de normbedragen aanpassen. Zie ook onder het kopje Vervolg.",
      "source": "ocr"
    },
