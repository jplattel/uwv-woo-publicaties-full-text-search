      "type": "paragraph",
      "page": 1,
      "bbox": [
        228.0,
        1520.0,
        1528.0,
        1546.0
      ],
      "text": "= E 17-II : de uurvergoeding voor intermediaire dienstverleners visueel en motorisch gehandicapten",
      "source": "ocr"
