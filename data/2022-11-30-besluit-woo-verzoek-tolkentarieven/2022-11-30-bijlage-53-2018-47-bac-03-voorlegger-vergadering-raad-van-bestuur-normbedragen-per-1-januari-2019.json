      "type": "paragraph",
      "page": 1,
      "bbox": [
        178.0,
        1217.0,
        1462.0,
        1243.0
      ],
      "text": "uitkomsten van dit onderzoek in beeld. Pas op het moment dat dit beeld helder is, zal UWV - als daar",
      "source": "ocr"
    },
