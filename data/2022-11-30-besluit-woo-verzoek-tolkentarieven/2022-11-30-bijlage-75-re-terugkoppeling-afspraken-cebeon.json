      "type": "paragraph",
      "page": 3,
      "bbox": [
        87.96,
        529.49,
        497.29,
        539.51
      ],
      "text": "Begin december volgende overleg (conceptrapport). UWV plant nieuw overleg in.",
      "source": "text"
    },
