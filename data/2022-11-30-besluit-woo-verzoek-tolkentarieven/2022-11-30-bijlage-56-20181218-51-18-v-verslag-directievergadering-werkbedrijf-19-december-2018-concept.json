      "type": "paragraph",
      "page": 1,
      "bbox": [
        109.8,
        703.77,
        435.29,
        712.77
      ],
      "text": "- Voorstellen voorleggen aan de Raad van Bestuur ter besluitvorming",
      "source": "text"
    },
