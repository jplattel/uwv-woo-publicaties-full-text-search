      "type": "paragraph",
      "page": 1,
      "bbox": [
        85.56,
        569.84,
        562.26,
        578.84
      ],
      "text": "betreft het aanpassingspercentage zoals opgenomen in de Regeling van het Ministerie van Sociale Zaken",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        85.56,
        580.76,
        409.29,
        589.76
      ],
      "text": "en Werkgelegenheid van 7 oktober 2020, nummer 2020 -0000133577;",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        67.56,
        591.68,
        530.89,
        600.68
      ],
      "text": "- Voor de normbedragen die worden geïndexeerd met dezelfde index als het maximum premieloon:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        85.56,
        602.72,
        119.08,
        611.72
      ],
      "text": "1,92%.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        49.56,
        618.57,
        73.29,
        627.57
      ],
      "text": "Ad. b",
      "source": "text"
    },
