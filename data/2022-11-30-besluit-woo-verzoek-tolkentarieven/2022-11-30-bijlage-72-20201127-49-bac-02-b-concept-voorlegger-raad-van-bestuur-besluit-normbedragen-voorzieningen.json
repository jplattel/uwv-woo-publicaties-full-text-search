      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        49.68,
        753.91,
        167.35,
        760.87
      ],
      "text": "Vervolgtraject besluitvorming",
      "source": "text"
    },
