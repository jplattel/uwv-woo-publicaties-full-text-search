    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        36.88,
        334.96,
        406.01,
        345.95
      ],
      "text": "We kijken in ieder geval naar opleidingsniveau en maatschappelijke functie/status.",
