    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        71.3,
        294.87,
        300.84,
        302.91
      ],
      "text": "Beslissing op uw verzoek om informatie d.d. 10-11-2022",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        412.18,
        305.07,
        415.83,
        313.11
      ],
