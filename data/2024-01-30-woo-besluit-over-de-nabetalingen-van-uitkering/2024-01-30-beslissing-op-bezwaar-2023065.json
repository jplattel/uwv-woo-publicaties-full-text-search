    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.82,
        558.61,
        470.98,
        567.61
      ],
      "text": "de beslissing een beroepschrift indienen bij de Rechtbank Groningen, afdeling algemeen",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.82,
        569.53,
        520.66,
        578.53
      ],
      "text": "bestuursrecht, Team Sociale Zekerheid, Ambtenarenrecht, WABO (milieu) en overig bestuursrecht,",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.82,
        580.45,
        225.21,
        589.45
      ],
      "text": "Postbus 150, 9700 AD Groningen.",
