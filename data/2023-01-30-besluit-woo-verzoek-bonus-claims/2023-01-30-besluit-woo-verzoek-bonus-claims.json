      "page": 1,
      "bbox": [
        70.8,
        435.81,
        121.62,
        444.81
      ],
      "text": "Beslissing",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        447.69,
        480.79,
        456.69
      ],
      "text": "UWV heeft, met inachtneming van uw verzoek, besloten de door u opgevraagde gegevens",
      "source": "text"
