      "type": "paragraph",
      "page": 1,
      "bbox": [
        106.8,
        529.42,
        143.8,
        538.42
      ],
      "text": "bestaat.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        552.22,
        208.25,
        561.22
      ],
