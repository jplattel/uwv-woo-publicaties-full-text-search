      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.81,
        423.56,
        121.62,
        432.56
      ],
      "text": "Beslissing",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.81,
        434.48,
        412.38,
        443.48
      ],
      "text": "UWV heeft besloten de door u opgevraagde informatie openbaar te maken.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.81,
        456.31,
        137.45,
        465.31
      ],
      "text": "Woo-verzoek",
