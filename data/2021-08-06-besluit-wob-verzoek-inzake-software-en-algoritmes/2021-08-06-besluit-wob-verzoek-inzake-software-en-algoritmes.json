    {
      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.94,
        311.75,
        511.08,
        320.75
      ],
      "text": "1d. Het door UWV gebruikte model detecteert namelijk geen onterechte claims. Het model levert",
      "source": "text"
