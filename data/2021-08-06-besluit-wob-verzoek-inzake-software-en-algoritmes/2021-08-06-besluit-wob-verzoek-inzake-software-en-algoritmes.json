      "page": 3,
      "bbox": [
        70.94,
        300.83,
        510.56,
        309.83
      ],
      "text": "UWV wijst uw verzoek ten aanzien van dit punt af onder verwijzing naar het gestelde onder punt",
      "source": "text"
