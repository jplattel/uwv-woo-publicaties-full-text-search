    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        319.28,
        215.3,
        334.28
      ],
      "text": "Op basis van 4 weken",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        70.82,
        349.73,
        274.42,
        361.25
      ],
      "text": "De formule wordt op basis van 4 weken:",
