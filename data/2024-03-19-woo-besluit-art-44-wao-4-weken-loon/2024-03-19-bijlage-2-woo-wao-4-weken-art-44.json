      "page": 1,
      "bbox": [
        121.82,
        756.1,
        213.99,
        767.62
      ],
      "text": "op maandbasis of",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        103.82,
        756.93,
        108.4,
