      "bbox": [
        70.82,
        469.81,
        137.43,
        478.81
      ],
      "text": "Woo-verzoek",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        480.73,
        508.83,
        489.73
      ],
      "text": "In uw verzoek is verzocht om de openbaarmaking van documenten met de volgende informatie:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.82,
        502.69,
        198.96,
        511.69
      ],
