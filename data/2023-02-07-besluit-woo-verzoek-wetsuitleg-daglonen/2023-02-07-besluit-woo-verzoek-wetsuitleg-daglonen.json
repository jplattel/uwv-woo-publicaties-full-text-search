      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        437.03,
        515.67,
        446.03
      ],
      "text": "UWV heeft besloten de aangetroffen documenten met de door u verzochte informatie openbaar te",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        447.95,
        104.55,
        456.95
      ],
