      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        392.39,
        497.65,
        401.39
      ],
      "text": "Op 13 januari 2023 heeft UWV uw verzoek om informatie op grond van de Wet open overheid",
      "source": "text"
