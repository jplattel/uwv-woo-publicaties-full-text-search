        69.24,
        146.73,
        322.41,
        155.73
      ],
      "text": "Aan de minister van Sociale Zaken en Werkgelegenheid",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        69.23,
        159.18,
        188.52,
