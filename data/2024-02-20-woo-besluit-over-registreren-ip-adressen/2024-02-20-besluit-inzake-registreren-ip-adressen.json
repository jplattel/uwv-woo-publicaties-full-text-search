      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.78,
        601.03,
        506.46,
        610.03
      ],
      "text": "niet alleen om beleidsstukken, maar bijvoorbeeld ook om e-mails, appjes etc. die gaan over het",
      "source": "text"
    },
