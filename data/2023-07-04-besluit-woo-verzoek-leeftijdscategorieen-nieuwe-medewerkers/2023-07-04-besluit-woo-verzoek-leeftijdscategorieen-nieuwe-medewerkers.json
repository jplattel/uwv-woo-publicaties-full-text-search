      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        467.23,
        341.3,
        476.23
      ],
      "text": "In uw verzoek heeft u verzocht om de volgende informatie:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        489.19,
        488.85,
        498.19
      ],
      "text": "Een overzicht van de werknemers die het UWV in de afgelopen drie jaar heeft aangenomen,",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        500.95,
        232.97,
        509.95
      ],
      "text": "ingedeeld naar leeftijdscategorieën.",
      "source": "text"
    },
