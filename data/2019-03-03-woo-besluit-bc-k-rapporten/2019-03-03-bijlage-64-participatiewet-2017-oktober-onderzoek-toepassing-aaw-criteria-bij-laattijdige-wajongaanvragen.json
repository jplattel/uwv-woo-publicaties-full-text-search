      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.82,
        238.52,
        520.33,
        247.52
      ],
      "text": "criterium dient te worden gehanteerd. Burgers die geboren zijn voor 1980 en een Wajongaanvraag",
      "source": "text"
    },
