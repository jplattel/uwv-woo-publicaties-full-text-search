      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.82,
        178.28,
        494.1,
        187.28
      ],
      "text": "Wanneer iemand een Wajonguitkering op een ander moment aanvraagt, spreken we van een",
      "source": "text"
