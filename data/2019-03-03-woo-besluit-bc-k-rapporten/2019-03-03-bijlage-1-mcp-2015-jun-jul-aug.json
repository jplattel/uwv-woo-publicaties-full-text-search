      "page": 3,
      "bbox": [
        106.82,
        504.61,
        518.39,
        513.61
      ],
      "text": "100 dossiers per maand voor de auditoren VA, waarvan 50 ZW- en 50 EWT WIA- dossiers,",
      "source": "text"
    },
