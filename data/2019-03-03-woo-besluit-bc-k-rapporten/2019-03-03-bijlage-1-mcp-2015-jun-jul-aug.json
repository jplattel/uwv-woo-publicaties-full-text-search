      "type": "paragraph",
      "page": 3,
      "bbox": [
        70.82,
        555.01,
        505.19,
        564.01
      ],
      "text": "Niet alle 600 dossiers hebben we kunnen toetsen, onder meer vanwege onderstaande redenen:",
      "source": "text"
    },
