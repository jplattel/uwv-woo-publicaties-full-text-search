      "type": "paragraph",
      "page": 1,
      "bbox": [
        106.21,
        595.65,
        334.76,
        604.65
      ],
      "text": "- Door wie en hoe worden gesprekken vastgelegd.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.81,
        618.33,
        208.26,
        627.33
      ],
