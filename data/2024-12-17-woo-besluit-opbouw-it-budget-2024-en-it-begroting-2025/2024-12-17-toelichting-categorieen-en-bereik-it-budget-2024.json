    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        49.68,
        101.47,
        518.98,
        110.47
      ],
      "text": "Wij sluiten in eerste instantie aan bij de door het UWV gebruikte categorisatie en bereik van de kosten.",
