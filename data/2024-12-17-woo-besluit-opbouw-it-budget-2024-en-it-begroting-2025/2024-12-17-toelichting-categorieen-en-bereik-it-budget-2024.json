    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.68,
        293.43,
        524.75,
        302.43
      ],
      "text": "over deze categorie. Verder lijken kosten die wel aan deze indeling zouden kunnen voldoen, vrij",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        88.68,
        305.42,
        185.56,
        314.42
      ],
      "text": "bescheiden van aard.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        49.68,
        329.42,
        508.24,
        338.42
      ],
