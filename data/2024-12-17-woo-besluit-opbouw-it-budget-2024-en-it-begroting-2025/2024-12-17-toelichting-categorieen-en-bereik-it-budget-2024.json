      "type": "paragraph",
      "page": 1,
      "bbox": [
        49.69,
        209.45,
        73.82,
        218.45
      ],
      "text": "en 4:",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.69,
        232.69,
        74.83,
        241.69
      ],
      "text": "•",
