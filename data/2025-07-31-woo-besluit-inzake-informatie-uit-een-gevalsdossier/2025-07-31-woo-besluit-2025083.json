      "bbox": [
        92.88,
        277.11,
        303.66,
        284.66
      ],
      "text": "Beslissing op uw verzoek om informatie d.d. 20-6-2025",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        413.28,
        288.35,
        453.25,
        293.98
      ],
