      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        89.98,
        134.04,
        412.24,
        144.0
      ],
      "text": "correspondeert met de bijbehorende grondslag in onderstaand overzicht.",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 2,
      "bbox": [
        93.24,
        156.18,
        199.99,
        168.18
      ],
      "text": "I Art. 5.1 lid 2 sub d",
      "source": "text"
    },
