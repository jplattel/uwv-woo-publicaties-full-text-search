    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        435.32,
        121.61,
        444.32
      ],
      "text": "Beslissing",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.8,
        446.24,
        515.63,
        455.24
      ],
      "text": "UWV heeft besloten de aangetroffen documenten met de door u verzochte informatie openbaar te",
      "source": "text"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        70.82,
        457.15,
        104.55,
        466.15
      ],
      "text": "maken.",
      "source": "text"
