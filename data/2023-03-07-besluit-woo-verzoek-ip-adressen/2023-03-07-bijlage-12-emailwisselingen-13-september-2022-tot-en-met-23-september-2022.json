    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        153.0,
        1048.0,
        1232.0,
        1076.0
      ],
      "text": "ons gesprek gaf jij aan dat dat al aanstaande maandag is, dus dat is positief.",
