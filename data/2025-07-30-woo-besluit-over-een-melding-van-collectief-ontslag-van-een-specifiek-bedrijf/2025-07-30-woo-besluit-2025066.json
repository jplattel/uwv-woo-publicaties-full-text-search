      "bbox": [
        200.0,
        819.0,
        818.0,
        842.0
      ],
      "text": "Beslissing op uw verzoek om informatie d.d. 18-5-2025",
      "source": "ocr"
    },
    {
      "type": "paragraph",
      "page": 1,
      "bbox": [
        1145.0,
        887.0,
        1262.0,
        901.0
      ],
      "text": "Uw kenmerk",
      "source": "ocr"
    },
    {
      "type": "heading",
      "page": 1,
      "bbox": [
        151.0,
        986.0,
        355.0,
